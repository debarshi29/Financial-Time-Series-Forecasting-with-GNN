        <!-- Standard graph caption -->
        <mxCell id="std_cap" value="Each edge e = (u, v) connects exactly 2 nodes.&lt;br/&gt;Group shocks must be decomposed into O(n²) pairwise edges.&lt;br/&gt;&lt;font color=&quot;#C0392B&quot;&gt;✗ Loses higher-order structure&lt;/font&gt;" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1">
