        <!-- Hypergraph caption -->
        <mxCell id="hyp_cap" value="Hyperedge e ⊆ V connects any subset of nodes.&lt;br/&gt;Single hyperedge represents an entire sector shock.&lt;br/&gt;Stocks have soft membership across overlapping themes.&lt;br/&gt;&lt;font color=&quot;#1E8449&quot;&gt;✓ Preserves higher-order market structure&lt;/font&gt;" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1">
